[Unit]
Description=Optuna Dashboard
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/workspace/code/nj-quant
ExecStart=/workspace/code/nj-quant/.venv/bin/optuna-dashboard sqlite:///workspace/code/nj-quant/optuna.db --host 0.0.0.0 --port 8080
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
